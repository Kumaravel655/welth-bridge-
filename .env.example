# ─── SMTP (used by the contact form and newsletter signup) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Where enquiries land ───
CONTACT_TO_EMAIL=

# ─── Where newsletter signup notifications land (optional, falls back to CONTACT_TO_EMAIL) ───
NEWSLETTER_TO_EMAIL=

# ─── Analytics (all optional — features no-op until set) ───
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
GOOGLE_SITE_VERIFICATION=

# ─── Client portal (Next.js talks to the FastAPI backend server-side only) ───
BACKEND_API_URL=http://localhost:8000
